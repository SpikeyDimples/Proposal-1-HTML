//]]></script><script src="./breyten_files/widget.js.download" id="rewards-widget" data-report-activity="false" data-dark-mode="false" data-settings="eyJ2ZXJ0aWNhbCI6ImltYWdlcyIsIm1hcmtldCI6ImVuLXphIn0=" async=""></script><style data-rewards-widget-styles="true" data-style-id="medallion:medallion-main">div[data-rewards-widget].medallion .dailyCheckAnimationContainer {
  height: 32px;
  width: 32px;
  display: flex;
}

